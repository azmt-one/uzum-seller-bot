# Telegram Bot API token from @BotFather
TELEGRAM_BOT_TOKEN=1234567890:replace_me

# Uzum Seller OpenAPI token.
# Важно: Uzum API использует заголовок Authorization БЕЗ префикса Bearer.
UZUM_API_TOKEN=replace_me

# Optional: restrict bot access to one Telegram user id.
# Узнать свой id можно у @userinfobot.
OWNER_TELEGRAM_ID=

# Optional: default shop id. If set, commands can be used without passing shop_id.
DEFAULT_SHOP_ID=

# Usually do not change.
UZUM_API_BASE_URL=https://api-seller.uzum.uz/api/seller-openapi
